rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isAdmin() {
      return request.auth != null
        && exists(userPath(request.auth.uid))
        && get(userPath(request.auth.uid)).data.role == 'admin';
    }

    function athleteLinkedToCoach(athleteUid) {
      return exists(userPath(athleteUid))
        && get(userPath(athleteUid)).data.coachId == request.auth.uid;
    }

    function swimmerLinkedToCoach(coachUid) {
      return exists(userPath(request.auth.uid))
        && get(userPath(request.auth.uid)).data.coachId == coachUid;
    }

    function swimmerCoachLinkPatchOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'coachId',
        'coachInviteLabel',
        'presetBirthYear',
        'presetCity',
        'presetPhone',
        'presetNotes',
        'trainingGroup',
        'updatedAt',
      ]);
    }

    match /coach_invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.coachId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.coachId == request.auth.uid;
    }

    match /coach_registration_requests/{requestId} {
      allow read: if request.auth != null && (isAdmin() || request.auth.uid == requestId);
      allow create: if request.auth != null
        && requestId == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        || (
          request.auth.uid == requestId
          && resource.data.uid == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending'
        )
        || (
          request.auth.uid == requestId
          && resource.data.uid == request.auth.uid
          && resource.data.status == 'rejected'
          && request.resource.data.status == 'rejected'
        )
        || (
          request.auth.uid == requestId
          && resource.data.uid == request.auth.uid
          && resource.data.status == 'rejected'
          && request.resource.data.status == 'pending'
        );
      allow delete: if isAdmin();
    }

    match /catalog_exercises/{exerciseId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /rank_norms/{rankId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || athleteLinkedToCoach(userId)
        || swimmerLinkedToCoach(userId)
        || ('coachId' in resource.data && resource.data.coachId == request.auth.uid)
        || isAdmin()
      );

      allow create: if request.auth != null
        && request.auth.uid == userId
        && (request.resource.data.role == 'swimmer' || request.resource.data.role == 'coach');

      allow delete: if request.auth != null && request.auth.uid == userId;

      allow update: if request.auth != null && (
        isAdmin()
        || (
          request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && (
            request.resource.data.coachId == resource.data.coachId
            || (!('coachId' in resource.data) && request.resource.data.coachId != null)
            || (resource.data.coachId == null && request.resource.data.coachId != null)
            || (
              swimmerCoachLinkPatchOnly()
              && request.resource.data.coachId is string
              && exists(userPath(request.resource.data.coachId))
              && get(userPath(request.resource.data.coachId)).data.role == 'coach'
            )
          )
        )
        || (
          athleteLinkedToCoach(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.coachId == resource.data.coachId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'trainingGroup',
            'updatedAt',
          ])
        )
      );

      match /workouts/{workoutId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId
          || ('coachId' in resource.data && resource.data.coachId == request.auth.uid)
          || athleteLinkedToCoach(userId)
          || isAdmin()
        );
        allow create: if request.auth != null && (
          request.auth.uid == userId
          || (
            athleteLinkedToCoach(userId)
            && request.resource.data.coachId == request.auth.uid
          )
          || isAdmin()
        );
        allow update: if request.auth != null && (
          request.auth.uid == userId
          || (
            athleteLinkedToCoach(userId)
            && (
              !('coachId' in resource.data)
              || resource.data.coachId == request.auth.uid
            )
          )
          || isAdmin()
        );
        allow delete: if request.auth != null && (
          request.auth.uid == userId
          || isAdmin()
        );
      }

      match /competition_swims/{swimId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId
          || athleteLinkedToCoach(userId)
          || isAdmin()
        );
        allow create, update, delete: if request.auth != null && (
          request.auth.uid == userId
          || isAdmin()
        );
      }

      match /performance_goal/{docId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId
          || athleteLinkedToCoach(userId)
          || isAdmin()
        );
        allow create, update, delete: if request.auth != null && (
          athleteLinkedToCoach(userId)
          || isAdmin()
        );
      }

      match /athleteDossiers/{athleteUid} {
        allow read, write: if request.auth != null && (
          request.auth.uid == userId
          || isAdmin()
        );
      }

      match /workout_templates/{templateId} {
        allow get, list: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
